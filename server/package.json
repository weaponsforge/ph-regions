{
  "name": "philippines",
  "version": "1.0.0",
  "type": "module",
  "description": "Regions, provinces and municipalities of the Philippines",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon",
    "start": "tsc && node dist/index.js",
    "transpile": "tsc -p tsconfig.json && tsc-alias",
    "transpile:noemit": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" *.mjs *.ts",
    "lint:fix": "eslint \"src/**/*.ts\" *.mjs *.ts --fix",
    "seed": "vite-node src/scripts/seed/main.ts"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.0.13",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite-node": "^3.2.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "mongoose": "^8.16.3",
    "ph-municipalities": "^1.4.4",
    "zod": "^4.0.5"
  }
}
